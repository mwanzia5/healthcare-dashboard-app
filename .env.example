# ─────────────────────────────────────────────────────
# MambaLabs Healthcare Dashboard — Environment Variables
# Copy this file: cp .env.example .env.local
# ─────────────────────────────────────────────────────

# Contact Form — Web3Forms (free, no backend needed)
# 1. Go to https://web3forms.com
# 2. Enter your email to receive a free access key
# 3. Paste the key below
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key_here

# Healthcare API Endpoints (example — replace with your actual API)
NEXT_PUBLIC_API_BASE_URL=https://api.your-healthcare-service.com/v1
NEXT_PUBLIC_PATIENT_API_ENDPOINT=/patients
NEXT_PUBLIC_APPOINTMENT_API_ENDPOINT=/appointments
NEXT_PUBLIC_VITALS_API_ENDPOINT=/vitals

# Mock Data Mode (set to "true" to use mock data instead of real API)
NEXT_PUBLIC_USE_MOCK_DATA=true

# Privacy & Security
NEXT_PUBLIC_ENCRYPTION_ENABLED=true
NEXT_PUBLIC_PRIVACY_NOTICE_VERSION=1.0

# Calendar Configuration
NEXT_PUBLIC_CALENDAR_PROVIDER=google # or "outlook", "custom"
NEXT_PUBLIC_CALENDAR_ID=primary

# Feature Flags
NEXT_PUBLIC_ENABLE_TELEMEDICINE=false
NEXT_PUBLIC_ENABLE_PRESCRIPTIONS=false
NEXT_PUBLIC_ENABLE_LAB_RESULTS=false

# UI/Theme
NEXT_PUBLIC_PRIMARY_COLOR=medical-blue
NEXT_PUBLIC_DASHBOARD_REFRESH_INTERVAL=30000 # milliseconds